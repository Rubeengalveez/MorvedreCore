# Supabase project URL.
# Local dev: http://127.0.0.1:54321 (default when running `supabase start`).
# Cloud: https://<project-ref>.supabase.co (Settings -> API -> Project URL).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (publishable) key. Safe to expose to the browser.
# Settings -> API -> Project API keys -> `anon` / `public`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service_role key. SERVER ONLY — never expose to the client.
# Used by scripts/bootstrap-admin.mjs and any Server Action that needs to
# bypass RLS (rare; prefer RLS-friendly flows). Settings -> API -> `service_role`.
# Rotate immediately if leaked.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional one-time password for `pnpm bootstrap`. If omitted, the script generates one.
ADMIN_TEMP_PASSWORD=replace-with-a-strong-one-time-password
SEED_PASSWORD=replace-with-a-local-demo-password

# Public URL of the Morvedre Core app. Used for auth redirects, email links,
# and CORS allow-lists in `supabase/config.toml` ([auth].additional_redirect_urls).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend: email provider for admin notifications (new access requests).
# Get an API key at https://resend.com. Free tier: 100 emails/day.
# The from address must be a verified domain in Resend.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=notificaciones@morvedrecore.app

# Email address where admin notifications are sent. Defaults to galvillo9@gmail.com.
ADMIN_EMAIL=galvillo9@gmail.com

# Shop manager email notified when a user sends a purchase request.
# Falls back to ADMIN_EMAIL when omitted.
SHOP_MANAGER_EMAIL=tienda@morvedrecore.app

# Treasury email used for test/automatic monthly closure delivery.
TREASURY_EMAIL=tesoreria@morvedrecore.app

# Web Push VAPID keys. Generate with `web-push generate-vapid-keys` or a trusted script.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@morvedrecore.app

# Optional credentials for authenticated Playwright tests. Never commit real values.
TEST_ADMIN_EMAIL=admin@example.com
TEST_PASSWORD=replace-with-a-test-only-password
